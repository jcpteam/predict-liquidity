#DB config if need：
db_type=mysql
db_host=127.0.0.1
db_port=3306
db_user=root
db_passwd=your_password
db_name=predict_liquidity

# Polymarket: 无需 API key 即可读取公开 order book
POLYMARKET_API_KEY=

# Kalshi: 需要注册获取 API key
KALSHI_API_KEY=

# Betfair: 通过 The Odds API 获取 Betfair Exchange 赔率
# 免费注册: https://the-odds-api.com (500 requests/month)
ODDS_API_KEY=

