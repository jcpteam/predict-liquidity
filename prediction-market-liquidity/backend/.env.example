#DB config if need：
db_type=mysql
db_host=127.0.0.1
db_port=3306
db_user=root
db_passwd=passwd
db_name=dbName

# Polymarket: 无需 API key 即可读取公开 order book
POLYMARKET_API_KEY=

# Kalshi: 需要注册获取 API key
KALSHI_API_KEY=

# Betfair: 需要 Application Key + Session Token
BETFAIR_API_KEY=
BETFAIR_SESSION_TOKEN=
